# Copy this file to .env and adjust as needed.

# Port the API is bound to on 127.0.0.1 (host side).
TUDO_PORT=8000

# Strongly recommended if this server is reachable from anywhere other than
# your own machine (e.g. behind a reverse proxy on a VPS). Clients must send
# "Authorization: Bearer <TUDO_API_KEY>" on every request when this is set.
# Leave empty to run without auth (fine for pure localhost use).
TUDO_API_KEY=changeme
